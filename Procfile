# Copia este archivo como .env y rellena tus datos de Supabase

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# Conexión a Supabase PostgreSQL
# Ve a Supabase → Settings → Database → Connection String (URI mode)
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# O usa variables separadas:
DB_HOST=db.[TU-PROJECT-REF].supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=TU-PASSWORD-AQUI
DB_SSL=true
